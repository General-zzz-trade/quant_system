# Bybit API (required for trading)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_BASE_URL=https://api-demo.bybit.com  # Change to https://api.bybit.com for live

# Binance API (optional - for data download and OI fetching)
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret

# Binance Testnet (optional - for paper trading)
# BINANCE_TESTNET_API_KEY=your_testnet_key
# BINANCE_TESTNET_API_SECRET=your_testnet_secret

# Polymarket (optional - for prediction market trading)
# POLYMARKET_API_KEY=your_polymarket_key
# POLYMARKET_API_SECRET=your_polymarket_secret

# Hyperliquid DEX (optional - for Hyperliquid perpetual futures)
# HYPERLIQUID_PRIVATE_KEY=your_ethereum_private_key_hex
# HYPERLIQUID_WALLET_ADDRESS=your_ethereum_wallet_address

# Telegram notifications (optional - for alerts and monitoring)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Risk management (optional - defaults shown)
# MAX_DAILY_DRAWDOWN_PCT=5.0

{
  "dashboard": {
    "id": null,
    "uid": "quant-trading",
    "title": "Quant Trading System",
    "tags": ["trading", "quant"],
    "timezone": "utc",
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "PnL (Cumulative)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "quant_pnl_total",
            "legendFormat": "PnL"
          }
        ]
      },
      {
        "id": 2,
        "title": "Pipeline Latency (ms)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(quant_pipeline_latency_ms_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(quant_pipeline_latency_ms_bucket[5m]))",
            "legendFormat": "p50"
          }
        ]
      },
      {
        "id": 3,
        "title": "Fill Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(quant_fills_total[5m])",
            "legendFormat": "fills/sec"
          }
        ]
      },
      {
        "id": 4,
        "title": "Order Rejection Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "rate(quant_orders_rejected_total[5m])",
            "legendFormat": "rejections/sec"
          }
        ]
      },
      {
        "id": 5,
        "title": "WebSocket Connection State",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "quant_ws_connection_state",
            "legendFormat": "{{state}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Rate Limit Utilization",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "quant_rate_limit_used / quant_rate_limit_capacity",
            "legendFormat": "{{pool}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Position Size (Notional)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "quant_position_notional",
            "legendFormat": "{{symbol}}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Market Data Age (sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "quant_market_data_age_sec",
            "legendFormat": "data_age"
          }
        ]
      }
    ]
  }
}

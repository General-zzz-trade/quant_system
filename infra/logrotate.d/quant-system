/quant_system/logs/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    maxsize 50M
    copytruncate
    su ubuntu ubuntu
}

/quant_system/data/runtime/decision_audit.jsonl {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    maxsize 100M
    copytruncate
    su ubuntu ubuntu
}

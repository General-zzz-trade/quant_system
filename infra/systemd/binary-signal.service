[Unit]
Description=Binary 5m RSI Signal (BTC)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/quant_system
EnvironmentFile=/quant_system/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -m scripts.run_binary_signal --symbol BTCUSDT --leverage 20 --bet-size 5000 --hold 300 --rsi-low 30 --rsi-high 70
Restart=on-failure
RestartSec=10
MemoryMax=128M

[Install]
WantedBy=multi-user.target
